<Window x:Class="FoulzExternal.features.games.universal.spotify.SpotifyOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Spotify" Width="260" SizeToContent="Height"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        Topmost="True" ShowInTaskbar="False" ResizeMode="NoResize"
        MouseLeftButtonDown="Window_MouseLeftButtonDown">
    <Border Background="#CC111111" CornerRadius="8" Padding="12,10" BorderBrush="#40FFFFFF" BorderThickness="0.5">
        <StackPanel>
            <!-- Header row -->
            <DockPanel Margin="0,0,0,6">
                <Ellipse x:Name="statusDot" Width="6" Height="6" Fill="#555" VerticalAlignment="Center" Margin="0,0,6,0"/>
                <TextBlock Text="Spotify" Foreground="#1DB954" FontSize="11" FontWeight="SemiBold" VerticalAlignment="Center"/>
                <TextBlock x:Name="txtStatus" Text="" Foreground="#555" FontSize="9" VerticalAlignment="Center" Margin="6,0,0,0"/>
            </DockPanel>

            <!-- Song info -->
            <TextBlock x:Name="txtSong" Text="-" Foreground="White" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis"/>
            <TextBlock x:Name="txtArtist" Text="-" Foreground="#AAA" FontSize="11" Margin="0,2,0,0" TextTrimming="CharacterEllipsis"/>

            <!-- Controls -->
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,2">
                <Button Content="⏮" Click="BtnPrev_Click"
                    Background="Transparent" Foreground="#888" BorderThickness="0" FontSize="14" Cursor="Hand" Padding="8,2" VerticalAlignment="Center"/>
                <Button Content="⏯" Click="BtnPlayPause_Click"
                    Background="Transparent" Foreground="White" BorderThickness="0" FontSize="18" Cursor="Hand" Padding="10,2" VerticalAlignment="Center"/>
                <Button Content="⏭" Click="BtnNext_Click"
                    Background="Transparent" Foreground="#888" BorderThickness="0" FontSize="14" Cursor="Hand" Padding="8,2" VerticalAlignment="Center"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
