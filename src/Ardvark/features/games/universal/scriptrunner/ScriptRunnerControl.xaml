<UserControl x:Class="FoulzExternal.features.games.universal.scriptrunner.ScriptRunnerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">

    <StackPanel>

        <!-- Header -->
        <TextBlock Text="SCRIPT RUNNER" Foreground="#333" FontSize="10"
                   FontWeight="Bold" Margin="0,0,0,12"/>

        <!-- File toolbar: dropdown + action buttons -->
        <Grid Margin="0,0,0,8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <ComboBox x:Name="ScriptDropdown"
                      Grid.Column="0"
                      Height="28"
                      Background="#0A0A0A"
                      Foreground="#CCC"
                      BorderBrush="#222"
                      BorderThickness="1"
                      Padding="6,3"
                      FontSize="11"
                      SelectionChanged="ScriptDropdown_SelectionChanged">
                <ComboBox.ItemContainerStyle>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#0A0A0A"/>
                        <Setter Property="Foreground" Value="#CCC"/>
                        <Setter Property="FontSize" Value="11"/>
                        <Setter Property="Padding" Value="6,3"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ComboBoxItem">
                                    <Border x:Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
                                        <ContentPresenter/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#1A1A1A"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                        <Trigger Property="IsSelected" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="#151515"/>
                                            <Setter Property="Foreground" Value="White"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ComboBox.ItemContainerStyle>
                <ComboBox.Template>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid>
                            <!-- Invisible toggle button fills entire area to handle clicks -->
                            <ToggleButton Focusable="False"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                          ClickMode="Press"
                                          Background="Transparent" BorderThickness="0">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="Bd" Background="#0A0A0A" BorderBrush="#222" BorderThickness="1" CornerRadius="3">
                                            <TextBlock x:Name="Arrow" Text="▾" Foreground="#555"
                                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                                       Margin="0,0,6,0" FontSize="10" IsHitTestVisible="False"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="Bd" Property="Background" Value="#111"/>
                                                <Setter TargetName="Arrow" Property="Foreground" Value="#888"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>
                            <!-- Selected item label overlaid, not hit-testable so clicks reach ToggleButton -->
                            <ContentPresenter x:Name="ContentSite"
                                              IsHitTestVisible="False"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                              VerticalAlignment="Center"
                                              Margin="6,0,20,0"/>
                            <Popup x:Name="PART_Popup"
                                   Placement="Bottom"
                                   IsOpen="{TemplateBinding IsDropDownOpen}"
                                   AllowsTransparency="True"
                                   Focusable="False"
                                   PopupAnimation="Fade"
                                   MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                   StaysOpen="False">
                                <Border Background="#0A0A0A" BorderBrush="#222" BorderThickness="1" CornerRadius="3" Padding="2">
                                    <ScrollViewer CanContentScroll="True" HorizontalScrollBarVisibility="Disabled" MaxHeight="200">
                                        <StackPanel IsItemsHost="True"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                    </ControlTemplate>
                </ComboBox.Template>
            </ComboBox>

            <Button x:Name="NewBtn" Grid.Column="1" Content="NEW"
                    Width="50" Height="28" Margin="5,0,0,0"
                    FontSize="10" FontWeight="Bold"
                    Background="#0D0D0D" Foreground="#888" BorderBrush="#222" BorderThickness="1"
                    Click="NewBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#151515"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="SaveBtn" Grid.Column="2" Content="SAVE"
                    Width="50" Height="28" Margin="5,0,0,0"
                    FontSize="10" FontWeight="Bold"
                    Background="#0D0D0D" Foreground="#888" BorderBrush="#222" BorderThickness="1"
                    Click="SaveBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#151515"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="OpenFolderBtn" Grid.Column="3" Content="📁"
                    Width="28" Height="28" Margin="5,0,0,0"
                    FontSize="12"
                    Background="#0D0D0D" Foreground="#888" BorderBrush="#222" BorderThickness="1"
                    Click="OpenFolderBtn_Click"
                    ToolTip="Open scripts folder">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#151515"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Code editor -->
        <Border BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="3" Margin="0,0,0,8">
            <TextBox x:Name="CodeEditor"
                     Height="300"
                     Background="#060606"
                     Foreground="#E0E0E0"
                     CaretBrush="White"
                     FontFamily="Consolas"
                     FontSize="12"
                     AcceptsReturn="True"
                     AcceptsTab="True"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Padding="8"
                     TextWrapping="NoWrap"
                     SpellCheck.IsEnabled="False"
                     Text="-- Write your script here&#x0a;print(&quot;Hello from FoulzExternal!&quot;)"/>
        </Border>

        <!-- Run / Stop row -->
        <Grid Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="RunBtn" Grid.Column="0" Content="▶  RUN"
                    Height="32" Margin="0,0,5,0"
                    FontSize="11" FontWeight="Bold"
                    Background="#0D0D0D" Foreground="#88FF88" BorderBrush="#1A1A1A" BorderThickness="1"
                    Click="RunBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bg" Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#111"/>
                                <Setter Property="Foreground" Value="#AAFFAA"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Button x:Name="StopBtn" Grid.Column="1" Content="■  STOP"
                    Width="90" Height="32"
                    FontSize="11" FontWeight="Bold"
                    Background="#0D0D0D" Foreground="#FF6666" BorderBrush="#1A1A1A" BorderThickness="1"
                    Click="StopBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#111"/>
                                <Setter Property="Foreground" Value="#FF9999"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Console output header -->
        <Grid Margin="0,0,0,5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="CONSOLE" Foreground="#333" FontSize="9" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button x:Name="ClearConsoleBtn" Grid.Column="1" Content="CLEAR"
                    Height="18" Padding="6,2"
                    FontSize="9"
                    Background="Transparent" Foreground="#444" BorderBrush="#1A1A1A" BorderThickness="1"
                    Click="ClearConsoleBtn_Click">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="{TemplateBinding BorderThickness}" CornerRadius="2">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="#888"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>
        </Grid>

        <!-- Console TextBox -->
        <Border BorderBrush="#1A1A1A" BorderThickness="1" CornerRadius="3">
            <TextBox x:Name="ConsoleOutput"
                     Height="130"
                     Background="#040404"
                     Foreground="#AAAAAA"
                     FontFamily="Consolas"
                     FontSize="11"
                     IsReadOnly="True"
                     HorizontalScrollBarVisibility="Auto"
                     VerticalScrollBarVisibility="Auto"
                     BorderThickness="0"
                     Padding="8"
                     TextWrapping="NoWrap"/>
        </Border>

    </StackPanel>
</UserControl>
