<UserControl x:Class="FoulzExternal.features.games.universal.explorer.ExplorerControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Height="Auto" Width="Auto">
	<UserControl.Resources>
		<LinearGradientBrush x:Key="hdr_grad" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="White" Offset="0"/>
			<GradientStop Color="#BFC3C6" Offset="1"/>
		</LinearGradientBrush>
		<LinearGradientBrush x:Key="item_grad" StartPoint="0,0" EndPoint="1,1">
			<GradientStop Color="#F6F6F6" Offset="0"/>
			<GradientStop Color="#D0D4D6" Offset="1"/>
		</LinearGradientBrush>
		<Style TargetType="TreeViewItem" x:Key="tree_style">
			<Setter Property="Foreground" Value="{StaticResource item_grad}"/>
			<Setter Property="Background" Value="Transparent"/>
			<Setter Property="Padding" Value="2"/>
			<Style.Triggers>
				<Trigger Property="IsSelected" Value="True">
					<Setter Property="Background" Value="#18FFFFFF"/>
				</Trigger>
				<Trigger Property="IsMouseOver" Value="True">
					<Setter Property="Background" Value="#08FFFFFF"/>
				</Trigger>
			</Style.Triggers>
		</Style>
		<Style TargetType="MenuItem" x:Key="ctx_item">
			<Setter Property="Foreground" Value="#CCC"/>
			<Setter Property="FontSize" Value="11"/>
			<Setter Property="Padding" Value="6,4"/>
		</Style>
	</UserControl.Resources>

	<Border BorderBrush="#111" BorderThickness="1" Background="#080808" CornerRadius="6" Padding="8">
		<Grid>
			<Grid.RowDefinitions>
				<RowDefinition Height="34"/>
				<RowDefinition Height="*"/>
			</Grid.RowDefinitions>

			<Border Background="#0B0B0B" CornerRadius="4" Padding="0,0,8,0">
				<DockPanel>
					<TextBlock Text="INSTANCE EXPLORER" VerticalAlignment="Center" Margin="12,0,0,0" FontSize="11" FontWeight="Bold" Foreground="{StaticResource hdr_grad}"/>
					<Button x:Name="btn_refresh" Content="⟳" DockPanel.Dock="Right" HorizontalAlignment="Right" Click="BtnRefresh_Click"
						Background="Transparent" Foreground="#999" BorderThickness="0" FontSize="14" Cursor="Hand" Padding="6,2" ToolTip="Refresh tree"/>
				</DockPanel>
			</Border>

			<Grid Grid.Row="1" Margin="0,5,0,0">
				<Grid.ColumnDefinitions>
					<ColumnDefinition Width="2*"/>
					<ColumnDefinition Width="1.2*"/>
				</Grid.ColumnDefinitions>

				<ScrollViewer Grid.Column="0" Background="#070707" VerticalScrollBarVisibility="Hidden">
					<TreeView x:Name="tree" Background="Transparent" BorderThickness="0" ItemContainerStyle="{StaticResource tree_style}"/>
				</ScrollViewer>

				<Border Grid.Column="1" Background="#0A0A0A" CornerRadius="6" Padding="10" Margin="8,0,0,0" BorderBrush="#111" BorderThickness="1">
					<ScrollViewer VerticalScrollBarVisibility="Auto">
						<StackPanel>
							<TextBlock Text="Properties" FontWeight="Bold" Foreground="White" Margin="0,0,0,10" FontSize="12"/>
							<TextBlock Text="Name" Foreground="#777" FontSize="10"/>
							<TextBlock x:Name="p_name" Text="-" Foreground="White" Margin="0,0,0,8"/>
							<TextBlock Text="Class" Foreground="#777" FontSize="10"/>
							<TextBlock x:Name="p_class" Text="-" Foreground="White" Margin="0,0,0,8"/>
							<TextBlock Text="Address" Foreground="#777" FontSize="10"/>
							<TextBlock x:Name="p_addr" Text="-" Foreground="#FFD799" Margin="0,0,0,8" FontSize="10"/>
							<TextBlock Text="Children" Foreground="#777" FontSize="10"/>
							<TextBlock x:Name="p_children" Text="-" Foreground="White" Margin="0,0,0,8"/>
							<TextBlock Text="Health" Foreground="#777" FontSize="10"/>
							<TextBlock x:Name="p_hp" Text="-" Foreground="White" Margin="0,0,0,8"/>
							<TextBlock Text="Position" Foreground="#777" FontSize="10"/>
							<TextBlock x:Name="p_pos" Text="-" Foreground="White" Margin="0,0,0,8"/>
							<TextBlock Text="Flagged" Foreground="#777" FontSize="10"/>
							<TextBlock x:Name="p_flagged" Text="-" Foreground="#FF6B6B" Margin="0,0,0,8"/>

							<Separator Background="#222" Margin="0,6"/>

							<Button x:Name="btn_teleport" Content="Teleport" Visibility="Collapsed" Click="BtnTeleport_Click"
								Background="#1A1A1A" Foreground="White" BorderBrush="#333" Padding="8,4" Margin="0,4" Cursor="Hand"/>
							<StackPanel x:Name="pnl_proximity" Visibility="Collapsed" Margin="0,4">
								<TextBlock Text="Hold Duration" Foreground="#777" FontSize="10"/>
								<Slider x:Name="sld_hold" Minimum="0" Maximum="10" Value="0" TickFrequency="0.1" IsSnapToTickEnabled="True"
									ValueChanged="SldHold_ValueChanged" Margin="0,2"/>
								<TextBlock x:Name="txt_hold" Text="0.0s" Foreground="White" FontSize="10"/>
							</StackPanel>
						</StackPanel>
					</ScrollViewer>
				</Border>
			</Grid>
		</Grid>
	</Border>
</UserControl>